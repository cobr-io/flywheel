# ImagePolicy: pick the latest tag using the Unix timestamp prefix.
# Tag format produced by image-builder-controller: <ts>-<short-sha>.
apiVersion: image.toolkit.fluxcd.io/v1
kind: ImagePolicy
metadata:
  name: {{ .AppName }}
  namespace: flux-system
spec:
  imageRepositoryRef:
    name: {{ .AppName }}
  filterTags:
    pattern: '^(?P<ts>\d+)-[a-f0-9]+$'
    extract: '$ts'
  policy:
    numerical:
      order: asc

apiVersion: source.toolkit.fluxcd.io/v1
kind: GitRepository
metadata:
  name: {{ .AppName }}
  # Builder infra lives in flywheel-system (where image-builder-controller
  # watches, via BUILDER_NAMESPACE) so the apps namespace holds only the
  # user's application workloads.
  namespace: {{ .FlywheelNamespace }}
  # Source provenance lives in flywheel.yaml's workspace block (keyed by
  # worktree), not on this resource: spec.url below always points at the
  # in-cluster bare repo and so cannot distinguish a local-only app from a
  # remote-backed one.
  # NOTE: no `kustomize.toolkit.fluxcd.io/reconcile: disabled` here. That
  # annotation, when present in the source manifest, causes Flux to SKIP
  # the resource entirely — including initial creation. git-auto-sync adds
  # the annotation imperatively after first create, preventing later
  # Flux reconciles from racing the spec.ref.branch field.
spec:
  interval: {{ .FluxIntervalLocal }}
  # The GitRepository is named after the app, but its source is the worktree's
  # bare repo (keyed by directory basename) — which may differ from the app name.
  url: {{ .GitServerURL }}/{{ .Worktree }}.git
  ref:
    # Initial branch on first apply; git-auto-sync owns this field after.
    branch: main

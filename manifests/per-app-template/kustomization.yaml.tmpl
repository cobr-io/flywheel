apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization
# Per-app builder folder for {{ .AppName }}. Generated by `flywheel
# add-app`; safe to hand-edit afterwards (the CLI emits files and walks
# away in v0.1; see design § flywheel add-app).
resources:
  - ./gitrepository.yaml
  - ./build-config.yaml
  - ./git-auto-sync.yaml
  - ./imagerepository.yaml
  - ./imagepolicy.yaml

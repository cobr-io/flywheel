apiVersion: apps/v1
kind: Deployment
metadata:
  name: git-auto-sync-{{ .AppName }}
  # Runs in flywheel-system (flywheel infra, alongside git-auto-sync-self) so
  # the apps namespace holds only your application workloads — not the sync
  # daemon. It patches its per-app GitRepository (also in flywheel-system, see
  # GITREPOSITORY_NAMESPACE below) on branch switches, using the flywheel-system
  # git-auto-sync Role from dev-loop rbac.yaml.
  namespace: flywheel-system
  labels:
    app: git-auto-sync
    worktree: {{ .AppName }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: git-auto-sync
      worktree: {{ .AppName }}
  template:
    metadata:
      labels:
        app: git-auto-sync
        worktree: {{ .AppName }}
    spec:
      serviceAccountName: git-auto-sync
      containers:
        - name: sync
          image: {{ .GitAutoSyncImage }}
          imagePullPolicy: IfNotPresent
          env:
            - name: WORKTREE
              value: /workspaces/{{ .Worktree }}
            - name: BARE_REPO_URL
              value: {{ .GitServerURL }}/{{ .Worktree }}.git
            - name: GITREPOSITORY_NAME
              value: {{ .AppName }}
            - name: GITREPOSITORY_NAMESPACE
              value: flywheel-system
          volumeMounts:
            - name: workspaces
              mountPath: /workspaces
          resources:
            requests:
              cpu: 10m
              memory: 32Mi
            limits:
              cpu: 200m
              memory: 128Mi
      volumes:
        - name: workspaces
          hostPath:
            path: /workspaces
            type: Directory

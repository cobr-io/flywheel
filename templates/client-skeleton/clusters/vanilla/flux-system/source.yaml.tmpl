# ─────────────────────────────────────────────────────────────────────────────
# Vanilla (flywheel-free) Flux entrypoint — the cluster's source of truth.
#
# This directory lets you bring the SAME local cluster up with stock Flux and
# zero `flywheel` binary — you forgo the fast dev loop. See
# docs/flywheel-free-bringup.md for the four-step bring-up.
#
# `flywheel up` does NOT use these files: it renders its own entrypoint at
# runtime and never reconciles ./clusters/, so this tree is inert during normal
# flywheel operation and only activates when you `kubectl apply -k` it. Applying
# it cleanly toggles the cluster's source from flywheel's in-cluster mirror to
# the GitHub remote below; the two workflows are mutually exclusive.
# ─────────────────────────────────────────────────────────────────────────────
apiVersion: source.toolkit.fluxcd.io/v1
kind: GitRepository
metadata:
  name: flux-system
  namespace: flux-system
spec:
  # Slow on purpose: there is no fast loop here, so don't hammer the remote.
  interval: 1m
  # The remote this cluster reconciles from. `flywheel init` runs `git init` on
  # a fresh repo with no origin, so it cannot know your real remote — this is a
  # best-effort guess. REPLACE the org/repo if it differs.
  url: https://github.com/{{ with .Org }}{{ . }}{{ else }}YOUR-ORG{{ end }}/{{ .ClientName }}.git
  ref:
    # The integration branch (matches git.integration_branch in flywheel.yaml).
    branch: main
  # Private repo? Create a `flux-system` secret (PAT or deploy key) in the
  # flux-system namespace and uncomment:
  # secretRef:
  #   name: flux-system

# Reconciles the client's own per-app builder folders. Sources from
# the client repo, not the Flywheel mirror.
apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: client-builders
  namespace: flux-system
spec:
  interval: {{ .FluxIntervalLocal }}
  prune: true
  sourceRef:
    kind: GitRepository
    name: flux-system
  path: ./builders/overlays/local
  dependsOn:
    - name: flywheel-dev-loop
  # Decrypt SOPS-encrypted secrets (*.enc.yaml) with the in-cluster sops-age
  # key, so client repos can ship encrypted secrets — mirrors flywheel-infra.
  decryption:
    provider: sops
    secretRef:
      name: sops-age
  # This is the client-builders Kustomization's subset of the image rewrites:
  # for any schema.ImageNames image whose ONLY Deployment is per-app-rendered
  # into this client repo's builders/ tree (rather than the shared
  # manifests/dev-loop/base), its ghcr.io ref would need rewriting here to
  # whatever `flywheel up` mirrored into the local registry — a dogfood
  # `:dogfood-<sha>` build or the released `:<version>` default — instead of in
  # the flywheel-dev-loop Kustomization. No current image fits that shape:
  # git-auto-sync, formerly the one example, is now a single controller in
  # dev-loop/base (docs/designs/2026-07-17-per-app-sync-controller-design.md),
  # so this block is presently empty; it stays wired for the next image that
  # does fit.
  #
  # Which images land here vs. the flywheel-dev-loop Kustomization (and why) is
  # decided by the bootstrapImageOwners table in
  # internal/cli/converge/bootstrap.go; this template ranges over the
  # .ClientBuilderImages slice that table produces. The whole `images:` key is
  # OMITTED when the slice is empty: a bare `images:` parses as YAML null, and
  # the Flux Kustomization CRD rejects an explicit null for the array field
  # ("spec.images in body must be of type array"), which silently dropped this
  # entire Kustomization from the bootstrap apply.
{{- if .ClientBuilderImages }}
  images:
{{- range .ClientBuilderImages }}
    - name: ghcr.io/cobr-io/{{ .Name }}
      newName: {{ .ImageName }}
      newTag: {{ .ImageTag }}
{{- end }}
{{- end }}

# git-auto-sync for the gitops repo ITSELF (the gitops-repo equivalent of
# a per-app `*-infra` git-auto-sync). Bidirectionally syncs the
# host-mounted worktree at /workspaces/{{ .RepoBaseName }} with the
# in-cluster bare repo the self-source GitRepository (flux-system) reads.
#
# Without this, commits to the gitops worktree never reach the cluster
# and Flux can't see new apps / overlay edits / branch switches. It also
# pulls Image-Automation's tag bumps (which IAC commits to the bare repo)
# back into the developer's worktree.
#
# Lives in flywheel-system (uses the git-auto-sync ServiceAccount + the
# git-auto-sync-flux-system Role from the dev-loop RBAC). Patches the
# flux-system GitRepository on branch switches.
apiVersion: apps/v1
kind: Deployment
metadata:
  name: git-auto-sync-self
  namespace: flywheel-system
  labels:
    app: git-auto-sync
    worktree: "{{ .RepoBaseName }}"
spec:
  replicas: 1
  selector:
    matchLabels:
      app: git-auto-sync
      worktree: "{{ .RepoBaseName }}"
  template:
    metadata:
      labels:
        app: git-auto-sync
        worktree: "{{ .RepoBaseName }}"
    spec:
      serviceAccountName: git-auto-sync
      containers:
        - name: sync
          image: {{ .GitAutoSyncImageRef }}
          imagePullPolicy: IfNotPresent
          env:
            - name: WORKTREE
              value: /workspaces/{{ .RepoBaseName }}
            - name: BARE_REPO_URL
              value: http://git-server.flywheel-system.svc.cluster.local:8080/{{ .RepoBaseName }}.git
            - name: GITREPOSITORY_NAME
              value: flux-system
            - name: GITREPOSITORY_NAMESPACE
              value: flux-system
            # Suspend this IUA during branch switches so image-automation
            # can't commit to the gitops bare repo mid-switch (Open Issue
            # #11). Only the gitops/self git-auto-sync sets these.
            - name: IUA_NAME
              value: flywheel-self
            - name: IUA_NAMESPACE
              value: flux-system
            # Poke the apps Kustomization to reconcile immediately after IUA's
            # image-tag bump lands in the bare repo (and after gitops edits),
            # collapsing two poll intervals out of the commit-to-pod loop. Only
            # the gitops/self sync sets this; per-app syncs leave it unset.
            - name: KUSTOMIZATION_NAME
              value: client-apps
            - name: KUSTOMIZATION_NAMESPACE
              value: flux-system
            # Opt-in branch following (issue #17). The gitops/self sync must
            # NOT repoint Flux on every local checkout: a transient checkout
            # (e.g. the one `git rebase` does) would deploy — and, with
            # prune:true, tear down — an infra-less branch tip. Choose the
            # deployed branch explicitly with `flywheel use <branch>`.
            - name: AUTO_FOLLOW_BRANCH
              value: "false"
            # Fall back here if the explicitly selected branch is deleted from
            # the gitops repo (graceful degradation + log).
            - name: DEFAULT_BRANCH
              value: "{{ .Branch }}"
          volumeMounts:
            - name: workspaces
              mountPath: /workspaces
          resources:
            requests:
              cpu: 10m
              memory: 32Mi
            limits:
              cpu: 200m
              memory: 128Mi
      volumes:
        - name: workspaces
          hostPath:
            path: /workspaces
            type: Directory

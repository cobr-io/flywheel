# Regenerated by `flywheel up` step 11 prelude from flywheel.yaml +
# flywheel.yaml.local. The keys here are the contract between the
# CLI and the in-cluster Flywheel components (per design § The
# `flywheel-config` ConfigMap).
#
# Nothing under paths.* or sops.* lands here — those are host-only or
# secret-only.
apiVersion: v1
kind: ConfigMap
metadata:
  name: flywheel-config
  namespace: flywheel-system
data:
  client.name: "{{ .ClientName }}"
  cluster.name: "{{ .ClusterName }}"
  cluster.registry: "{{ .Registry }}"
  cluster.registry_port: "{{ .RegistryPort }}"
  namespaces.flywheel: "flywheel-system"
  namespaces.apps: "apps"
  flux.interval_local: "{{ .FluxIntervalLocal }}"
  local.domain: "{{ .Domain }}"
  # Read by git-deploy-controller: the gitops repo basename (it derives WORKTREE
  # + BARE_REPO_URL from this) and the AUTHORED fallback branch.
  repo.base_name: "{{ .RepoBaseName }}"
  git.integration_branch: "{{ .IntegrationBranch }}"

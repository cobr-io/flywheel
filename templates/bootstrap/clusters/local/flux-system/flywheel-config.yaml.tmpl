# Regenerated by `flywheel up` step 11d as part of the bootstrap flux-system
# tree. The keys here are the contract between the CLI and the in-cluster
# Flywheel components (per design § The `flywheel-config` ConfigMap).
#
# The `data` block is NOT hardcoded here: it is rendered by ranging over
# `.FlywheelConfigData`, the single producer map (converge.FlywheelConfigData),
# which the step-11 prelude direct apply (converge.ApplyFlywheelConfig) uses
# too — so the two writers can never diverge. text/template visits map keys in
# sorted order, so this render is deterministic.
#
# Nothing under paths.* or sops.* lands here — those are host-only or
# secret-only.
apiVersion: v1
kind: ConfigMap
metadata:
  name: flywheel-config
  namespace: {{ .FlywheelNamespace }}
data:
{{- range $key, $value := .FlywheelConfigData }}
  {{ $key }}: "{{ $value }}"
{{- end }}

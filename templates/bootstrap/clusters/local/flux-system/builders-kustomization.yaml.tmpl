apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: flywheel-dev-loop
  namespace: flux-system
spec:
  # Mirror-sourced Flywheel content changes only on `flywheel up` (which
  # applies it directly via client-go in the bootstrap dance), so this poll
  # is a slow fallback, not the delivery path. Kept long deliberately: a
  # routine 10s reconcile flips Ready=Unknown for ~260ms each cycle, and any
  # dependent (client-builders) that evaluates dependsOn during that blink
  # eats a --requeue-dependency penalty. At 5m the blink is ~0.09% of the
  # time instead of ~2.6%, which is what removes the commit-to-pod outlier.
  interval: 5m
  prune: true
  sourceRef:
    kind: GitRepository
    name: flywheel
  path: ./manifests/dev-loop/overlays/local
  # SSA via Flux's default fieldManager so the bootstrap dance's
  # client-go apply (with fieldManager=flux-controller) hands over
  # cleanly.
  force: true
  # Rewrite the mirror's generic ghcr.io image refs to the resolved
  # refs `flywheel up` step 9 loaded into containerd (cfg.flywheel.images
  # overrides if set, else the published ghcr.io defaults at the pinned
  # version). These values are rendered fresh by `flywheel up` on every
  # invocation — this file is bootstrap-only, never committed to the
  # gitops repo, so .local edits flow through on the next `up`.
  # git-server, image-builder-controller, and git-deploy-controller have
  # Deployments under this dev-loop overlay, so their refs are rewritten here to
  # match the step-11a direct apply (renderDevLoopKustomization) — otherwise Flux
  # would re-apply the base ghcr.io ref and the pod would ErrImagePull.
  # git-auto-sync is NOT rewritten here — its Deployments are the per-app builders
  # (rewritten by the client-builders Kustomization's spec.images), so a
  # flywheel.images override reaches git-auto-sync through that path, not this one.
  images:
    - name: ghcr.io/cobr-io/git-server
      newName: {{ .GitServerImageName }}
      newTag: {{ .GitServerImageTag }}
    - name: ghcr.io/cobr-io/image-builder-controller
      newName: {{ .ImageBuilderControllerImageName }}
      newTag: {{ .ImageBuilderControllerImageTag }}
    - name: ghcr.io/cobr-io/git-deploy-controller
      newName: {{ .GitDeployControllerImageName }}
      newTag: {{ .GitDeployControllerImageTag }}
  # git-server memory limit (cfg.git_server.memory_limit, default 128Mi). The
  # base manifest bakes in 128Mi; this patch lets a client raise it for large
  # repos whose git-upload-pack would otherwise OOMKill the pod (issue #4).
  # Rendered fresh on every `up`, so a change reconciles onto a live cluster —
  # and matches the limit the step-11a direct apply (ApplyDevLoop) sets, so the
  # two paths don't fight.
  patches:
    - patch: |-
        apiVersion: apps/v1
        kind: Deployment
        metadata:
          name: git-server
          namespace: flywheel-system
        spec:
          template:
            spec:
              containers:
                - name: git-server
                  resources:
                    limits:
                      memory: {{ .GitServerMemoryLimit }}
